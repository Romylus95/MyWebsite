---
import CommandPalette from '../components/CommandPalette';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Dimitris Meliopoulos вЂ” .NET Software Engineer',
  description = 'Personal portfolio and CV of Dimitris Meliopoulos, a .NET Software Engineer.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- Theme: apply before paint to avoid flash -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>

  <body class="bg-bg text-text font-sans transition-colors duration-300 antialiased">

    <!-- в”Ђв”Ђ Overlays & decorative (pointer-events: none) в”Ђв”Ђ -->
    <div id="page-loader"       aria-hidden="true"><p class="loader-logo">DM<span>_</span></p></div>
    <div id="cursor-spotlight"  aria-hidden="true"></div>
    <div id="cursor-dot"        aria-hidden="true"></div>
    <div id="cursor-ring"       aria-hidden="true"></div>
    <svg class="grain" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <filter id="grain-f">
        <feTurbulence type="fractalNoise" baseFrequency="0.72" numOctaves="4" stitchTiles="stitch"/>
        <feColorMatrix type="saturate" values="0"/>
      </filter>
      <rect width="100%" height="100%" filter="url(#grain-f)"/>
    </svg>

    <!-- в”Ђв”Ђ Toasts в”Ђв”Ђ -->
    <div id="konami-toast" role="status" aria-live="polite">
      рџЋ® Achievement unlocked: You&rsquo;re a nerd
    </div>

    <!-- в”Ђв”Ђ Floating CTA в”Ђв”Ђ -->
    <div id="floating-cta" aria-label="Contact me">
      <a href="#contact">Let&rsquo;s talk <span aria-hidden="true">в†’</span></a>
    </div>

    <CommandPalette client:load />
    <slot />

    <!-- в”Ђв”Ђ Scripts в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ -->

    <!-- Scroll reveal -->
    <script is:inline>
      var revealObs = new IntersectionObserver(function(entries) {
        entries.forEach(function(e) {
          if (e.isIntersecting) { e.target.classList.add('visible'); revealObs.unobserve(e.target); }
        });
      }, { threshold: 0.1 });
      document.querySelectorAll('.reveal').forEach(function(el) { revealObs.observe(el); });
    </script>

    <!-- Enable smooth scroll only after page load (prevents smooth scroll restoration on reload) -->
    <script is:inline>
      window.addEventListener('load', function() {
        document.documentElement.style.scrollBehavior = 'smooth';
      });
    </script>

    <!-- Page loader -->
    <script is:inline>
      (function() {
        var l = document.getElementById('page-loader');
        if (!l) return;
        setTimeout(function() {
          l.style.opacity = '0';
          setTimeout(function() { l.remove(); }, 500);
        }, 420);
      })();
    </script>

    <!-- Cursor spotlight -->
    <script is:inline>
      var sp = document.getElementById('cursor-spotlight');
      if (sp) {
        document.addEventListener('mousemove', function(e) {
          sp.style.background = 'radial-gradient(520px circle at '+e.clientX+'px '+e.clientY+'px,rgba(94,234,212,0.06),transparent 40%)';
        });
      }
    </script>

    <!-- Custom cursor -->
    <script is:inline>
      (function() {
        if (!window.matchMedia('(pointer:fine)').matches) return;
        var dot  = document.getElementById('cursor-dot');
        var ring = document.getElementById('cursor-ring');
        if (!dot || !ring) return;
        var mx = -999, my = -999, rx = -999, ry = -999;
        document.addEventListener('mousemove', function(e) {
          mx = e.clientX; my = e.clientY;
          dot.style.left = mx + 'px'; dot.style.top = my + 'px';
        });
        (function tick() {
          rx += (mx - rx) * 0.14; ry += (my - ry) * 0.14;
          ring.style.left = rx + 'px'; ring.style.top = ry + 'px';
          requestAnimationFrame(tick);
        })();
        document.addEventListener('mouseleave', function() { dot.style.opacity='0'; ring.style.opacity='0'; });
        document.addEventListener('mouseenter', function() { dot.style.opacity='1'; ring.style.opacity='1'; });
        document.addEventListener('mousedown',  function() { dot.classList.add('clicking'); ring.classList.add('clicking'); });
        document.addEventListener('mouseup',    function() { dot.classList.remove('clicking'); ring.classList.remove('clicking'); });
        document.querySelectorAll('a,button,[role="button"],label,input,summary').forEach(function(el) {
          el.addEventListener('mouseenter', function() { dot.classList.add('hovering'); ring.classList.add('hovering'); });
          el.addEventListener('mouseleave', function() { dot.classList.remove('hovering'); ring.classList.remove('hovering'); });
        });
      })();
    </script>

    <!-- Floating CTA -->
    <script is:inline>
      (function() {
        var cta     = document.getElementById('floating-cta');
        var contact = document.getElementById('contact');
        if (!cta) return;
        window.addEventListener('scroll', function() {
          var past   = window.scrollY > window.innerHeight * 0.75;
          var nearContact = contact && contact.getBoundingClientRect().top < window.innerHeight * 0.85;
          cta.classList.toggle('visible', past && !nearContact);
        });
      })();
    </script>

    <!-- Text scramble on section headings -->
    <script is:inline>
      (function() {
        var CHARS = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789@#$%&*';
        function scramble(el) {
          var orig = el.textContent;
          var iter = 0;
          var iv = setInterval(function() {
            el.textContent = orig.split('').map(function(ch, i) {
              if (ch === ' ') return ' ';
              if (i < iter)  return orig[i];
              return CHARS[Math.floor(Math.random() * CHARS.length)];
            }).join('');
            iter += 0.55;
            if (iter >= orig.length) { el.textContent = orig; clearInterval(iv); }
          }, 32);
        }
        document.querySelectorAll('section h2').forEach(function(h) {
          var obs = new IntersectionObserver(function(entries) {
            if (!entries[0].isIntersecting) return;
            obs.disconnect();
            setTimeout(function() { scramble(h); }, 180);
          }, { threshold: 0.5 });
          obs.observe(h);
        });
      })();
    </script>

    <!-- Console easter egg -->
    <script is:inline>
      console.log('%c\n  в–€в–€в–€в–€в–€в–€в•— в–€в–€в–€в•—   в–€в–€в–€в•—\n  в–€в–€в•”в•ђв•ђв–€в–€в•—в–€в–€в–€в–€в•— в–€в–€в–€в–€в•‘\n  в–€в–€в•‘  в–€в–€в•‘в–€в–€в•”в–€в–€в–€в–€в•”в–€в–€в•‘\n  в–€в–€в•‘  в–€в–€в•‘в–€в–€в•‘в•љв–€в–€в•”в•ќв–€в–€в•‘\n  в–€в–€в–€в–€в–€в–€в•”в•ќв–€в–€в•‘ в•љв•ђв•ќ в–€в–€в•‘\n  в•љв•ђв•ђв•ђв•ђв•ђв•ќ в•љв•ђв•ќ     в•љв•ђв•ќ\n','color:#5eead4;font-family:monospace;font-size:10px;line-height:1.5;');
      console.log('%cHey, I see you snooping around! рџ‘Ђ\n%cIf you find a bug вЂ” it\'s a feature, I promise.\n%cdmeliopoulos95@gmail.com','color:#e2e8f0;font-size:13px;font-weight:bold;font-family:monospace;','color:#94a3b8;font-size:12px;font-family:monospace;','color:#5eead4;font-size:12px;font-family:monospace;');
    </script>

    <!-- Konami code + confetti -->
    <script is:inline>
      (function() {
        var SEQ = ['ArrowUp','ArrowUp','ArrowDown','ArrowDown','ArrowLeft','ArrowRight','ArrowLeft','ArrowRight','b','a'];
        var idx = 0;
        document.addEventListener('keydown', function(e) {
          idx = (e.key === SEQ[idx]) ? idx + 1 : (e.key === SEQ[0] ? 1 : 0);
          if (idx === SEQ.length) { idx = 0; showToast('рџЋ® Achievement unlocked: You\'re a nerd'); launchConfetti(); }
        });

        function showToast(msg) {
          var t = document.getElementById('konami-toast');
          if (!t) return;
          t.textContent = msg; t.classList.add('show');
          setTimeout(function() { t.classList.remove('show'); }, 3200);
        }

        function launchConfetti() {
          var cv = document.createElement('canvas');
          cv.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:9998;';
          document.body.appendChild(cv);
          cv.width = window.innerWidth; cv.height = window.innerHeight;
          var ctx = cv.getContext('2d'); if (!ctx) return;
          var C = ['#5eead4','#82aaff','#c792ea','#c3e88d','#f78c6c','#ffcb6b','#ff5370'];
          var ps = Array.from({length:140},function(){return{x:Math.random()*cv.width,y:Math.random()*cv.height*-0.5,w:Math.random()*9+4,h:Math.random()*5+3,c:C[Math.random()*C.length|0],vx:Math.random()*3-1.5,vy:Math.random()*4+2.5,a:Math.random()*Math.PI*2,s:(Math.random()-0.5)*0.18,f:1};});
          var fr=0;(function draw(){ctx.clearRect(0,0,cv.width,cv.height);ps.forEach(function(p){p.x+=p.vx;p.y+=p.vy;p.a+=p.s;if(fr>110)p.f=Math.max(0,p.f-0.018);ctx.save();ctx.globalAlpha=p.f;ctx.translate(p.x,p.y);ctx.rotate(p.a);ctx.fillStyle=p.c;ctx.fillRect(-p.w/2,-p.h/2,p.w,p.h);ctx.restore();});fr++;if(fr<175)requestAnimationFrame(draw);else cv.remove();})();
        }

        // Logo 5Г— click в†’ hacker mode (wired via custom event from Nav)
        window.addEventListener('hacker-mode', function() {
          document.documentElement.classList.add('hacker-mode');
          showToast('рџ–ҐпёЏ H4CK3R M0D3 ACTIVATED');
          setTimeout(function() { document.documentElement.classList.remove('hacker-mode'); }, 3500);
        });
      })();
    </script>

  </body>
</html>

<style is:global>
  /* в”Ђв”Ђ @property for animatable accent colour в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
  @property --color-accent {
    syntax: '<color>';
    inherits: true;
    initial-value: #0d9488;
  }

  /* в”Ђв”Ђ Design tokens в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
  :root {
    --color-bg:      #f1f5f9;
    --color-surface: #ffffff;
    --color-border:  rgba(0, 0, 0, 0.08);
    --color-text:    #0f172a;
    --color-muted:   #64748b;
    --color-accent:  #0d9488;
  }

  .dark {
    --color-bg:      #0a0f1e;
    --color-surface: #0d1526;
    --color-border:  rgba(255, 255, 255, 0.07);
    --color-text:    #e2e8f0;
    --color-muted:   #94a3b8;
    --color-accent:  #5eead4;
  }

/* в”Ђв”Ђ Scroll reveal в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .reveal.visible { opacity: 1; transform: translateY(0); }

  /* в”Ђв”Ђ Staggered entrance в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
  .stagger-container > .reveal:nth-child(1) { transition-delay:   0ms; }
  .stagger-container > .reveal:nth-child(2) { transition-delay: 100ms; }
  .stagger-container > .reveal:nth-child(3) { transition-delay: 200ms; }
  .stagger-container > .reveal:nth-child(4) { transition-delay: 300ms; }
  .stagger-container > .reveal:nth-child(5) { transition-delay: 400ms; }
  .stagger-container > .reveal:nth-child(6) { transition-delay: 500ms; }
  .stagger-container > .reveal:nth-child(7) { transition-delay: 600ms; }
  .stagger-container > .reveal:nth-child(8) { transition-delay: 700ms; }

  /* в”Ђв”Ђ Scrollbar в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
  ::-webkit-scrollbar        { width: 6px; }
  ::-webkit-scrollbar-track  { background: var(--color-bg); }
  ::-webkit-scrollbar-thumb  { background: var(--color-border); border-radius: 3px; }

  /* в”Ђв”Ђ Selection в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
  ::selection { background: var(--color-accent); color: #0a0f1e; }

  /* scroll-behavior applied via JS after load to avoid smooth scroll restoration on reload */

  /* в”Ђв”Ђ Page loader в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
  #page-loader {
    position: fixed; inset: 0; z-index: 9999;
    background: #0a0f1e;
    display: flex; align-items: center; justify-content: center;
    transition: opacity 0.5s ease;
  }
  .loader-logo {
    font-family: 'JetBrains Mono', monospace;
    font-size: 1.4rem; font-weight: 600;
    color: #5eead4; letter-spacing: 0.12em;
  }
  .loader-logo span { animation: blink 1s step-end infinite; }

  /* в”Ђв”Ђ Cursor spotlight в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
  #cursor-spotlight {
    position: fixed; inset: 0; z-index: 9;
    pointer-events: none; opacity: 0; transition: opacity 0.4s ease;
  }
  .dark #cursor-spotlight { opacity: 1; }

  /* в”Ђв”Ђ Custom cursor в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
  @media (pointer: fine) {
    *, *::before, *::after { cursor: none !important; }

    #cursor-dot {
      position: fixed; top: 0; left: 0; z-index: 99999;
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--color-accent);
      pointer-events: none;
      transform: translate(-50%, -50%);
      transition: width 0.2s, height 0.2s, background 0.2s, transform 0.1s;
    }
    #cursor-ring {
      position: fixed; top: 0; left: 0; z-index: 99998;
      width: 32px; height: 32px; border-radius: 50%;
      border: 1.5px solid var(--color-accent);
      pointer-events: none; opacity: 0.45;
      transform: translate(-50%, -50%);
      transition: width 0.22s ease, height 0.22s ease, opacity 0.2s, border-color 0.3s;
    }
    #cursor-dot.hovering  { width: 10px; height: 10px; }
    #cursor-ring.hovering { width: 50px; height: 50px; opacity: 0.22; }
    #cursor-dot.clicking  { transform: translate(-50%,-50%) scale(0.7); }
    #cursor-ring.clicking { width: 26px; height: 26px; opacity: 0.6; }
  }


  /* в”Ђв”Ђ Grain texture в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
  .grain {
    position: fixed; inset: 0; width: 100%; height: 100%;
    pointer-events: none; z-index: 9998;
  }
  .dark            .grain { opacity: 0.038; }
  :root:not(.dark) .grain { opacity: 0.018; }

  /* в”Ђв”Ђ Floating CTA в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
  #floating-cta {
    position: fixed; bottom: 2rem; right: 2rem; z-index: 100;
    transform: translateY(5rem); opacity: 0; pointer-events: none;
    transition: transform 0.4s cubic-bezier(0.175,0.885,0.32,1.275), opacity 0.3s ease;
  }
  #floating-cta.visible { transform: translateY(0); opacity: 1; pointer-events: auto; }
  #floating-cta a {
    display: flex; align-items: center; gap: 6px;
    padding: 0.6rem 1.15rem;
    background: var(--color-accent); color: #0a0f1e;
    border-radius: 999px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem; font-weight: 600;
    text-decoration: none;
    animation: fab-pulse 3s ease-in-out infinite;
  }
  @keyframes fab-pulse {
    0%,100% { box-shadow: 0 4px 20px color-mix(in srgb,var(--color-accent) 35%,transparent); }
    50%      { box-shadow: 0 4px 34px color-mix(in srgb,var(--color-accent) 58%,transparent); }
  }

  /* в”Ђв”Ђ Konami toast в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
  #konami-toast {
    position: fixed; bottom: 1.5rem; left: 50%;
    transform: translateX(-50%) translateY(5rem);
    z-index: 9997;
    background: var(--color-surface); border: 1px solid var(--color-border);
    color: var(--color-text);
    font-family: 'JetBrains Mono', monospace; font-size: 0.78rem;
    padding: 0.55rem 1.2rem; border-radius: 999px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.35);
    opacity: 0; pointer-events: none;
    transition: transform 0.4s cubic-bezier(0.175,0.885,0.32,1.275), opacity 0.3s ease;
    white-space: nowrap;
  }
  #konami-toast.show { transform: translateX(-50%) translateY(0); opacity: 1; }

  /* в”Ђв”Ђ Hacker mode в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
  html.hacker-mode,
  html.hacker-mode body { background: #000 !important; }
  html.hacker-mode * {
    color: #00ff41 !important;
    font-family: 'JetBrains Mono', monospace !important;
    border-color: rgba(0,255,65,0.3) !important;
    animation: none !important;
    text-shadow: 0 0 8px rgba(0,255,65,0.6) !important;
  }

  /* в”Ђв”Ђ Print / PDF в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
  @media print {
