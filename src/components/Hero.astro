---
import TypedText from './TypedText';
import LiveClock from './LiveClock';
const stack = ['C#', '.NET Core', 'ASP.NET', 'Azure', 'SQL Server', 'Docker', 'REST APIs', 'SOAP APIs'];
const currently = 'Working at Chubb as .NET Engineer 💼';
---

<section
  id="hero"
  class="relative min-h-screen flex items-center pt-16 pb-20 px-6 overflow-hidden"
>
  <!-- Dot grid background -->
  <div class="hero-dot-grid" aria-hidden="true"></div>

  <div class="max-w-6xl mx-auto w-full relative z-10">

    <!-- Bento Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 auto-rows-auto">

      <!-- Card 1: Main intro (large, spans 2 cols) -->
      <div
        class="bento-card tilt-card md:col-span-2 p-8 flex flex-col justify-between min-h-[300px] animate-fade-up"
        style="animation-delay: 0ms"
      >
        <div>
          <p class="font-mono text-accent text-sm mb-3 tracking-widest">Hi, my name is</p>
          <h1 class="text-4xl md:text-5xl font-bold text-text leading-tight mb-2">
            <span class="name-hover">Dimitris
              <span class="name-tip" aria-hidden="true">
                <span class="name-avatar">DM</span>
                <span class="name-tip-label">That&rsquo;s me! 👋</span>
              </span>
            </span><br />Meliopoulos<span class="text-accent">.</span>
          </h1>
          <h2 class="text-xl md:text-2xl font-semibold text-muted mt-2 mb-5">
            <TypedText client:load />
          </h2>
          <p class="text-muted text-sm md:text-base leading-relaxed">
            Senior software developer with 6+ years of experience designing, building and maintaining software systems. Specialised in .NET backend development, API & system design, and delivering reliable solutions across enterprise environments.
          </p>
        </div>
        <div class="flex flex-wrap gap-3 mt-8">
          <a
            href="#projects"
            class="magnetic-btn px-5 py-2.5 bg-accent text-[#0a0f1e] font-semibold text-sm rounded-lg hover:opacity-90 transition-all duration-150 inline-block"
          >
            See my work
          </a>
          <a
            href="#contact"
            class="magnetic-btn px-5 py-2.5 border border-[var(--color-border)] text-text font-semibold text-sm rounded-lg hover:border-accent hover:text-accent transition-all duration-150 inline-block"
          >
            Get in touch
          </a>
        </div>
      </div>

      <!-- Card 2: Stack pills -->
      <div
        class="bento-card tilt-card p-6 flex flex-col gap-4 animate-fade-up"
        style="animation-delay: 80ms"
      >
        <p class="font-mono text-accent text-xs tracking-widest uppercase">Tech Stack</p>
        <div class="flex flex-wrap gap-2">
          {
            stack.map((tech) => (
              <span class="px-3 py-1.5 text-xs font-mono rounded-md bg-[var(--color-border)] text-muted hover:text-accent hover:border-accent border border-transparent transition-colors cursor-default">
                {tech}
              </span>
            ))
          }
        </div>
        <div class="mt-auto pt-4 border-t border-[var(--color-border)]">
          <p class="text-xs text-muted">
            Primarily focused on backend .NET development.
          </p>
        </div>
      </div>

      <!-- Card 3: Status + Live clock + Currently -->
      <div
        class="bento-card tilt-card p-6 flex flex-col gap-4 animate-fade-up"
        style="animation-delay: 160ms"
      >
        <!-- Availability -->
        <div class="flex items-center gap-2">
          <span class="relative flex h-2.5 w-2.5 shrink-0">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-emerald-500"></span>
          </span>
          <span class="text-xs font-mono text-muted">Open to opportunities</span>
        </div>

        <!-- Live clock -->
        <div class="flex items-center gap-2 border-t border-[var(--color-border)] pt-4">
          <span class="text-sm" aria-hidden="true">🇬🇷</span>
          <LiveClock client:load />
          <span class="text-xs font-mono text-muted ml-1">Thessaloniki</span>
        </div>

        <!-- Currently -->
        <div class="border-t border-[var(--color-border)] pt-4 mt-auto">
          <p class="font-mono text-[10px] text-muted uppercase tracking-widest mb-1">currently</p>
          <p class="text-xs text-text leading-snug">{currently}</p>
        </div>
      </div>

      <!-- Card 4: About snippet -->
      <div
        class="bento-card tilt-card md:col-span-2 p-6 animate-fade-up"
        style="animation-delay: 240ms"
      >
        <p class="font-mono text-accent text-xs tracking-widest uppercase mb-3">Quick About</p>
        <p class="text-muted text-sm leading-relaxed">
          I'm a .NET Software Engineer based in Thessaloniki, Greece. I work across the full
          backend stack — from API design and database modelling to cloud deployments on Azure.
          I enjoy working on challenging problems, writing clean maintainable code, and
          collaborating in teams that care about quality.
        </p>
        <div class="flex gap-5 mt-5">
          <a
            href="https://github.com/Romylus95"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub"
            class="text-muted hover:text-accent transition-colors"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
            </svg>
          </a>
          <a
            href="https://www.linkedin.com/in/dimitris-meliopoulos-00107a168/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            class="text-muted hover:text-accent transition-colors"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <a
            href="/cv.pdf"
            download
            aria-label="Download CV"
            class="text-muted hover:text-accent transition-colors flex items-center gap-1.5 text-xs font-mono"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
              <polyline points="7 10 12 15 17 10"/>
              <line x1="12" y1="15" x2="12" y2="3"/>
            </svg>
            Resume
          </a>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  /* ── Dot grid ───────────────────────────────────────── */
  .hero-dot-grid {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, color-mix(in srgb, var(--color-accent) 18%, transparent) 1px, transparent 1px);
    background-size: 28px 28px;
    animation: dot-drift 20s linear infinite;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 100%);
    -webkit-mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 100%);
    opacity: 0.5;
    z-index: 0;
  }
  :root:not(.dark) .hero-dot-grid { opacity: 0.25; }

  @keyframes dot-drift {
    from { background-position: 0 0; }
    to   { background-position: 28px 28px; }
  }

  .bento-card {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.5s ease;
    will-change: transform;
    transform-style: preserve-3d;
  }

  /* ── Name hover photo ─────────────────────────── */
  .name-hover {
    position: relative;
    display: inline-block;
    cursor: default;
  }
  .name-tip {
    position: absolute;
    bottom: calc(100% + 10px);
    left: 50%;
    transform: translateX(-50%) translateY(8px) scale(0.88);
    opacity: 0;
    pointer-events: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    transition: opacity 0.25s ease, transform 0.25s ease;
    z-index: 50;
    white-space: nowrap;
  }
  .name-hover:hover .name-tip {
    opacity: 1;
    transform: translateX(-50%) translateY(0) scale(1);
  }
  .name-avatar {
    width: 72px; height: 72px; border-radius: 50%;
    background: linear-gradient(135deg, var(--color-accent), #82aaff);
    display: flex; align-items: center; justify-content: center;
    font-family: 'Inter', sans-serif;
    font-size: 1.3rem; font-weight: 700; color: #0a0f1e;
    box-shadow: 0 8px 28px color-mix(in srgb, var(--color-accent) 40%, transparent);
    /* Replace with: background-image: url('/photo.jpg'); background-size: cover; */
  }
  .name-tip-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.68rem; color: var(--color-muted);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    padding: 2px 8px; border-radius: 999px;
  }

  .bento-card:hover {
    border-color: color-mix(in srgb, var(--color-accent) 30%, transparent);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--color-accent) 10%, transparent),
                0 8px 32px color-mix(in srgb, var(--color-accent) 5%, transparent);
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.tilt-card').forEach((card) => {
    card.addEventListener('mouseenter', () => {
      card.style.transition =
        'transform 0.12s ease, border-color 0.2s ease, box-shadow 0.2s ease';
    });

    card.addEventListener('mousemove', (e) => {
      const { left, top, width, height } = card.getBoundingClientRect();
      const x = (e.clientX - left) / width  - 0.5; // -0.5 → 0.5
      const y = (e.clientY - top)  / height - 0.5;
      card.style.transition =
        'transform 0.06s linear, border-color 0.2s ease, box-shadow 0.2s ease';
      card.style.transform =
        `perspective(800px) rotateY(${x * 8}deg) rotateX(${-y * 8}deg) scale3d(1.015, 1.015, 1.015)`;
    });

    card.addEventListener('mouseleave', () => {
      card.style.transition =
        'transform 0.5s ease, border-color 0.2s ease, box-shadow 0.2s ease';
      card.style.transform =
        'perspective(800px) rotateY(0deg) rotateX(0deg) scale3d(1, 1, 1)';
    });
  });

  // ── Magnetic buttons ────────────────────────────────────────
  document.querySelectorAll<HTMLElement>('.magnetic-btn').forEach((btn) => {
    btn.addEventListener('mousemove', (e) => {
      const { left, top, width, height } = btn.getBoundingClientRect();
      const dx = (e.clientX - (left + width  / 2)) * 0.28;
      const dy = (e.clientY - (top  + height / 2)) * 0.28;
      btn.style.transition = 'transform 0.1s ease';
      btn.style.transform  = `translate(${dx}px, ${dy}px)`;
    });

    btn.addEventListener('mouseleave', () => {
      btn.style.transition = 'transform 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275)';
      btn.style.transform  = 'translate(0, 0)';
    });
  });
</script>
