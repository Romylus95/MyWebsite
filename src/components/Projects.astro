];

// Seeded heatmap (server-side, no JS needed)
function rnd(n: number) { const x = Math.sin(n * 9301 + 49297) * 233280; return x - Math.floor(x); }
const WEEKS = 18;
const heatmap: number[][] = Array.from({ length: WEEKS }, (_, w) =>
  Array.from({ length: 7 }, (_, d) => {
    const r = rnd(w * 7 + d + 42) - ((d === 0 || d === 6) ? 0.15 : 0);
    return r < 0.42 ? 0 : r < 0.60 ? 1 : r < 0.74 ? 2 : r < 0.87 ? 3 : 4;
  })
);
