</section>

<script>
  (function () {
    var track = document.getElementById('h-scroll-track');
    var thumb = document.getElementById('h-scrollbar-thumb');
    var bar   = document.getElementById('h-scrollbar-track');
    if (!track || !window.matchMedia('(min-width: 768px)').matches) return;

    var targetX  = 0;
    var currentX = 0;
    var rafId    = 0;

    function updateThumb() {
      var scrollable = track.scrollWidth - track.clientWidth;
      if (scrollable <= 0) { if (bar) bar.style.display = 'none'; return; }
      var thumbRatio = track.clientWidth / track.scrollWidth;
      var thumbW     = Math.max(thumbRatio * 100, 8);
      var barW       = bar ? bar.clientWidth : 0;
      var maxOffset  = barW - (barW * thumbRatio);
      var offset     = (track.scrollLeft / scrollable) * maxOffset;
      if (thumb) { thumb.style.width = thumbW + '%'; thumb.style.transform = 'translateX(' + offset + 'px)'; }
    }

    function tick() {
      currentX += (targetX - currentX) * 0.1;
      track.scrollLeft = currentX;
      updateThumb();
      if (Math.abs(targetX - currentX) > 0.5) {
        rafId = requestAnimationFrame(tick);
      } else {
        track.scrollLeft = targetX;
        updateThumb();
        rafId = 0;
      }
    }

    // Wheel over the cards area → horizontal scroll
    // Only intercept when there is actual horizontal room in the scroll direction
    track.addEventListener('wheel', function (e) {
      if (Math.abs(e.deltaY) <= Math.abs(e.deltaX)) return;
      var maxScroll = track.scrollWidth - track.clientWidth;
      var newTarget = Math.max(0, Math.min(maxScroll, targetX + e.deltaY * 1.5));
      if (newTarget === targetX) return; // already at boundary — let page scroll through
      e.preventDefault();
      currentX = track.scrollLeft;
      targetX  = newTarget;
      if (!rafId) rafId = requestAnimationFrame(tick);
    }, { passive: false });

    window.addEventListener('load', updateThumb);
    window.addEventListener('resize', updateThumb);
  })();
</script>

<style>
  .project-card {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
    min-height: 280px;
  }
  .project-card:hover {
    border-color: color-mix(in srgb, var(--color-accent) 30%, transparent);
    transform: translateY(-4px);
    box-shadow: 0 10px 32px color-mix(in srgb, var(--color-accent) 8%, transparent);
  }

  /* Desktop horizontal scroll track */
  #h-scroll-track {
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding-left:  max(1.5rem, calc((100vw - 72rem) / 2));
    padding-right: max(1.5rem, calc((100vw - 72rem) / 2));
    padding-bottom: 0.5rem;
  }
  #h-scroll-track::-webkit-scrollbar { display: none; }

  #h-scrollbar-thumb { transition: transform 0.05s linear; }

  /* Heatmap */
  .heatmap      { display: flex; gap: 2px; }
  .heatmap-col  { display: flex; flex-direction: column; gap: 2px; }
  .heatmap-cell { width: 10px; height: 10px; border-radius: 2px; transition: opacity 0.15s; }
  .heatmap-cell:hover { opacity: 0.65; }
  .heat-0 { background: var(--color-border); }
  .heat-1 { background: color-mix(in srgb, var(--color-accent) 22%, transparent); }
  .heat-2 { background: color-mix(in srgb, var(--color-accent) 44%, transparent); }
  .heat-3 { background: color-mix(in srgb, var(--color-accent) 66%, transparent); }
  .heat-4 { background: color-mix(in srgb, var(--color-accent) 88%, transparent); }

  /* Print: show normal flow */
  @media print {
    #h-scroll-track { overflow: visible; flex-wrap: wrap; }
  }
</style>
