    <!-- Custom scrollbar — wheel events only active when hovering this area -->
    <div class="max-w-6xl mx-auto px-6">
      <div id="h-scrollbar-container" class="py-3">
        <div id="h-scrollbar-track" class="w-full h-[2px] rounded-full" style="background: var(--color-border)">
